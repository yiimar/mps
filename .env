################################
# ENV   dev|stage|production
################################
APP_ENV=dev
DOCKER_CONTEXT=./app/docker

################################
# app
################################
APP_URL=http://localhost:8080
APP_VOLUMES_HOST=./app
APP_VOLUMES_CONTAINER=/data/app


################################
# NGINX
################################
NGINX_PORT_HOST=8080
NGINX_PORT_CONTAINER=80

################################
# Paths
################################
APP_CODE_PATH_HOST=./
APP_CODE_PATH_CONTAINER=/app
DATA_PATH_HOST=~/.docker/data

################################
# MySQL
################################
MYSQL_VERSION=mysql:8.3.0
MYSQL_ROOT_HOST: localhost
MYSQL_DATABASE: mps
MYSQL_USER: mps
MYSQL_PASSWORD: secretE
MYSQL_ROOT_PASSWORD: secretR
MYSQL_PORT=33061
